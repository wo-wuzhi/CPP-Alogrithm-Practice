# --- C++ 编译产物 (绝对不要上传) ---
*.exe          # Windows 可执行文件
*.o            # Linux/Mac 目标文件
*.obj          # Windows 目标文件
*.dll          # 动态链接库
*.so           # Linux 共享库
*.dylib        # Mac 动态库
*.out          # 常见的输出文件
a.out          # GCC 默认输出
main.exe       # 针对你当前项目的特定忽略

# --- 构建目录 (如果有) ---
build/
bin/
Debug/
Release/
x64/
x86/

# --- IDE 配置文件 (可选，建议忽略) ---
.vscode/       # VS Code 的本地配置（如 launch.json 等，除非你想分享调试配置）
*.code-workspace

# --- 系统文件 ---
.DS_Store      # Mac 系统文件
Thumbs.db      # Windows 缩略图缓存